//@version=6
strategy("bO_qQi-NJEo 9/21 Scalping Strategy [Profile Toggle]", overlay=true, initial_capital=100000, pyramiding=0, process_orders_on_close=true, default_qty_type=strategy.fixed, default_qty_value=1)

// Generated from:
// projects/analysis/analysis_bO_qQi-NJEo_20260412_175501.json
// Inferred core logic:
// 1) 9/21 EMA trend context.
// 2) Pullback entry when candle closes between EMAs.
// 3) RSI momentum filter around level 50.
// 4) Partial take profit and runner exit.

groupProfile = "Profile"
groupSignal = "Signal Rules"
groupRisk = "Risk"
groupExecution = "Execution"
groupDisplay = "Display"
groupGex = "GEX Filter"

profilePreset = input.string("Manual", "Profile Preset", options=["Manual", "Balanced", "Conservative", "Aggressive", "Trend", "Retest"], group=groupProfile, tooltip="Switch between pre-tuned parameter sets for quick testing.")

fastLenInput = input.int(9, "Fast EMA", minval=1, group=groupSignal)
slowLenInput = input.int(21, "Slow EMA", minval=2, group=groupSignal)
rsiLenInput = input.int(14, "RSI Length", minval=2, group=groupSignal)
rsiLevelInput = input.float(50.0, "RSI Midline", minval=1, maxval=99, step=0.5, group=groupSignal)
requirePullbackColorInput = input.bool(true, "Require Pullback Candle Color", group=groupSignal, tooltip="Long uses red pullback candle, short uses green pullback candle.")
useRsiFilterInput = input.bool(true, "Use RSI Filter", group=groupSignal)

pipSize = input.float(0.25, "Pip/Tick Size", minval=0.00001, step=0.00001, group=groupRisk, tooltip="NQ is often 0.25. Adjust per instrument.")
maxEntryPipsInput = input.float(5.0, "Max Entry Distance (pips)", minval=0.1, step=0.1, group=groupRisk)
tp1PipsInput = input.float(10.0, "TP1 (pips)", minval=0.5, step=0.5, group=groupRisk)
tp2PipsInput = input.float(20.0, "TP2 (pips)", minval=0.5, step=0.5, group=groupRisk)
stopPipsInput = input.float(15.0, "Stop Loss (pips)", minval=0.5, step=0.5, group=groupRisk)
tp1ClosePctInput = input.float(50.0, "TP1 Close %", minval=1, maxval=99, step=1, group=groupRisk)
useMomentumExitInput = input.bool(true, "Exit Runner On Momentum Flip", group=groupRisk)

contractsPerTrade = input.int(1, "Contracts Per Trade", minval=1, group=groupExecution)
allowLongs = input.bool(true, "Allow Longs", group=groupExecution)
allowShorts = input.bool(true, "Allow Shorts", group=groupExecution)

showEntrySignals = input.bool(true, "Show Entry Markers", group=groupDisplay)
showProfileTable = input.bool(true, "Show Profile Table", group=groupDisplay)

gexAsset = input.string("BTC", "GEX Asset", options=["BTC", "NQ", "ES"], group=groupGex, tooltip="BTC disables GEX filter/exit. NQ and ES use their matching GEX blocks.")
useGexFilter = input.bool(true, "Use GEX Entry Filter", group=groupGex, tooltip="Long: net gamma > 0 and not near resistance. Short: net gamma <= 0 and not near support.")
gexBandPts = input.float(20.0, "Near-Level Band (Points)", minval=0.25, step=0.25, group=groupGex)
useGexExit = input.bool(true, "Use GEX Protective Exit", group=groupGex, tooltip="Closes long near overhead GEX resistance and short near lower GEX support.")
useHistoricalGexDataset = input.bool(true, "Use Historical GEX Dataset", group=groupGex, tooltip="If enabled, strategy uses date-matched GEX levels from the historical dataset block when available.")
applyGexToHistory = input.bool(false, "Apply GEX To Historical Bars", group=groupGex, tooltip="OFF = only apply GEX from Active-From date forward, to avoid distorting older history with current levels.")
gexActiveFrom = input.time(1776038400000, "GEX Active From (Exchange Time)", group=groupGex)
showGexLevels = input.bool(true, "Show Nearest GEX Levels", group=groupGex)

effectiveFastLen = profilePreset == "Manual" ? fastLenInput : profilePreset == "Conservative" ? 9 : profilePreset == "Aggressive" ? 8 : profilePreset == "Trend" ? 12 : profilePreset == "Retest" ? 9 : 9
effectiveSlowLen = profilePreset == "Manual" ? slowLenInput : profilePreset == "Conservative" ? 24 : profilePreset == "Aggressive" ? 18 : profilePreset == "Trend" ? 30 : profilePreset == "Retest" ? 21 : 21
effectiveRsiLen = profilePreset == "Manual" ? rsiLenInput : profilePreset == "Aggressive" ? 10 : 14
effectiveRsiLevel = profilePreset == "Manual" ? rsiLevelInput : 50.0
effectiveUseRsiFilter = profilePreset == "Manual" ? useRsiFilterInput : true
effectiveRequirePullbackColor = profilePreset == "Manual" ? requirePullbackColorInput : true
effectiveMaxEntryPips = profilePreset == "Manual" ? maxEntryPipsInput : profilePreset == "Conservative" ? 4.0 : profilePreset == "Aggressive" ? 7.0 : profilePreset == "Trend" ? 6.0 : profilePreset == "Retest" ? 5.0 : 5.0
effectiveTp1Pips = profilePreset == "Manual" ? tp1PipsInput : profilePreset == "Conservative" ? 8.0 : profilePreset == "Aggressive" ? 12.0 : 10.0
effectiveTp2Pips = profilePreset == "Manual" ? tp2PipsInput : profilePreset == "Conservative" ? 15.0 : profilePreset == "Aggressive" ? 30.0 : profilePreset == "Trend" ? 35.0 : 20.0
effectiveStopPips = profilePreset == "Manual" ? stopPipsInput : profilePreset == "Conservative" ? 12.0 : profilePreset == "Aggressive" ? 18.0 : 15.0
effectiveTp1ClosePct = profilePreset == "Manual" ? tp1ClosePctInput : profilePreset == "Aggressive" ? 40.0 : 50.0
effectiveUseMomentumExit = profilePreset == "Manual" ? useMomentumExitInput : true

