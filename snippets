GEXBOT_BASE_URL=https://api.gexbot.com
TICKERS=NQ_NDX,ES_SPX
AGGREGATION_PERIOD=zero
START_DATE=2026-04-17
END_DATE=2026-04-18
TOP_N=20
TIMEOUT=30
SLEEP_MS=250
OUT_DIR=pinescript-agents/projects/analysis/gexbot_data/historical
FUTURE_DAYS=30
GEX_BLOCK_MAX_DAYS=45
MULTI_ASSET_STRATEGY_PATH=pinescript-agents/projects/gex-compatible-strategies/multi_asset/BTC_tradingview_scalp_strategy.pine
