//@version=6
strategy("Learn The 9-20 EMA Crossover Intraday Trading Strategy In... [Auto ORB]", overlay=true, initial_capital=100000, pyramiding=0, process_orders_on_close=true, default_qty_type=strategy.fixed, default_qty_value=1)

// Generated from analysis JSON:
// projects\analysis\analysis_ema-9-20-crossover-intraday-auto-orb-strategy_20260412_100303.json
// Model assumptions:
// 1) Opening range breakout on first session window.
// 2) Optional retest confirmation before entry.
// 3) EMA trend filter (9/20), plus fixed-R partial exits.

groupSession = "Session"
groupSignals = "Signal Rules"
groupRisk = "Risk"
groupDisplay = "Display"
groupExecution = "Execution"
groupOptimization = "Optimization Presets"
groupGex = "GEX Filter"
groupDebug = "Debug"

sessionInput = input.session("0930-1600", "Trading Session", group=groupSession, tooltip="Session used to define opening range.")
sessionTz = input.string("America/New_York", "Session Timezone", options=["America/New_York", "America/Chicago", "Etc/UTC"], group=groupSession)
orbMinutes = input.int(30, "Opening Range Minutes", minval=5, maxval=120, group=groupSession)

profilePreset = input.string("Manual", "Profile Preset", options=["Manual", "Balanced", "Conservative", "Aggressive", "Trend", "Retest"], group=groupOptimization, tooltip="Use presets for faster parameter sweeps in Strategy Tester.")

fastEmaLen = input.int(9, "Fast EMA", minval=1, group=groupSignals)
slowEmaLen = input.int(20, "Slow EMA", minval=1, group=groupSignals)
useTrendFilter = input.bool(true, "Use EMA Trend Filter", group=groupSignals, tooltip="Turn off to test raw ORB breakout frequency.")
requireRetest = input.bool(false, "Require Retest Confirmation", group=groupSignals, tooltip="If enabled, price must retest the breakout level before entry.")

riskPct = input.float(0.35, "Risk % (vs entry)", minval=0.05, step=0.05, group=groupRisk)
tp1R = input.float(1.0, "TP1 (R multiple)", minval=0.5, step=0.25, group=groupRisk)
tp2R = input.float(2.0, "TP2 (R multiple)", minval=1.0, step=0.25, group=groupRisk)
moveStopToBreakEven = input.bool(false, "Move Stop To Break-Even After TP1", group=groupRisk)

showLevels = input.bool(true, "Show ORB Levels", group=groupDisplay)
showSignals = input.bool(true, "Show Signal Markers", group=groupDisplay)
contractsPerTrade = input.int(1, "Contracts Per Trade", minval=1, group=groupExecution, tooltip="Use fixed contracts for futures. Percent-of-equity can round to 0 contracts.")
useGexFilter = input.bool(true, "Use GEX Entry Filter", group=groupGex, tooltip="Long: net gamma > 0 and not near resistance. Short: net gamma <= 0 and not near support.")
gexBandPts = input.float(20.0, "Near-Level Band (Points)", minval=0.25, step=0.25, group=groupGex)
useGexExit = input.bool(true, "Use GEX Protective Exit", group=groupGex, tooltip="Closes long near overhead GEX resistance and short near lower GEX support.")
useHistoricalGexDataset = input.bool(true, "Use Historical GEX Dataset", group=groupGex, tooltip="If enabled, strategy uses date-matched GEX levels from the historical dataset block when available.")
requireMatchedHistoricalGex = input.bool(false, "Require Matched Historical GEX", group=groupGex, tooltip="If ON, strategy will only use GEX filters/exits when a same-day historical GEX row is matched.")
applyGexToHistory = input.bool(false, "Apply GEX To Historical Bars", group=groupGex, tooltip="OFF = only apply GEX from Active-From date forward, to avoid distorting older history with current levels.")
gexActiveFrom = input.time(1776038400000, "GEX Active From (Exchange Time)", group=groupGex)
showGexLevels = input.bool(true, "Show Nearest GEX Levels", group=groupGex)
showPresetTable = input.bool(false, "Show Preset Table", group=groupDebug, tooltip="Displays active effective parameters on chart.")

effectiveOrbMinutes = profilePreset == "Manual" ? orbMinutes : profilePreset == "Conservative" ? 45 : profilePreset == "Aggressive" ? 20 : 30
effectiveFastEma = profilePreset == "Manual" ? fastEmaLen : profilePreset == "Conservative" ? 12 : profilePreset == "Aggressive" ? 7 : profilePreset == "Trend" ? 15 : profilePreset == "Retest" ? 9 : 9
effectiveSlowEma = profilePreset == "Manual" ? slowEmaLen : profilePreset == "Conservative" ? 30 : profilePreset == "Aggressive" ? 18 : profilePreset == "Trend" ? 30 : profilePreset == "Retest" ? 20 : 20
effectiveUseTrend = profilePreset == "Manual" ? useTrendFilter : true
effectiveRequireRetest = profilePreset == "Manual" ? requireRetest : profilePreset == "Retest"
effectiveRiskPct = profilePreset == "Manual" ? riskPct : profilePreset == "Conservative" ? 0.25 : profilePreset == "Aggressive" ? 0.50 : 0.35
effectiveTp1R = profilePreset == "Manual" ? tp1R : profilePreset == "Aggressive" ? 1.25 : 1.0
effectiveTp2R = profilePreset == "Manual" ? tp2R : profilePreset == "Conservative" ? 1.75 : profilePreset == "Aggressive" ? 2.5 : 2.0
effectiveMoveToBE = profilePreset == "Manual" ? moveStopToBreakEven : profilePreset != "Aggressive"

