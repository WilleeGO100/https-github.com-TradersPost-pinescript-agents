float gexSpotEs = 6855.4
string gexGeneratedAtEs = "2026-04-13T08:11:49.825586+00:00"
string gexSourceUrlEs = "https://api.gexbot.com/ES_SPX/classic/zero"
var float[] gexStrikesEs = array.from(6828.42, 6833.42, 6838.42, 6843.42, 6848.42, 6853.42, 6858.42, 6863.42, 6873.42)
var float[] gexGammaEs = array.from(-7218.03, -7048.05, -24712.71, -31151.73, -47906.43, 708448.7, 196779.22, 27821.35, -6999.65)
// --- END AUTO-GENERATED GEX BLOCK (ES_SPX) ---

// --- BEGIN AUTO-GENERATED HISTORICAL GEX DATASET (ES_SPX) ---
// day_key format: YYYYMMDD (exchange date)
// pipe-delimited rows must align by index with gexHistDayKeysEs
var int[] gexHistDayKeysEs = array.from(20260413)
var string[] gexHistStrikesCsvEs = array.from("6828.42|6833.42|6838.42|6843.42|6848.42|6853.42|6858.42|6863.42|6873.42")
var string[] gexHistGammaCsvEs = array.from("-7218.03|-7048.05|-24712.71|-31151.73|-47906.43|708448.7|196779.22|27821.35|-6999.65")
// --- END AUTO-GENERATED HISTORICAL GEX DATASET (ES_SPX) ---

f_parse_csv_to_float_array(string csv, float[] outArr) =>
    array.clear(outArr)
    tokens = str.split(csv, "|")
    for i = 0 to array.size(tokens) - 1
        v = str.tonumber(array.get(tokens, i))
        if not na(v)
            array.push(outArr, v)

var float[] activeGexStrikes = array.new_float()
var float[] activeGexGamma = array.new_float()
var int loadedGexDayKey = na
var string loadedGexAsset = ""

dayKey = year(time) * 10000 + month(time) * 100 + dayofmonth(time)
assetUsesGex = gexAsset != "BTC"
if not assetUsesGex
    loadedGexDayKey := dayKey
    loadedGexAsset := gexAsset
    array.clear(activeGexStrikes)
    array.clear(activeGexGamma)
if assetUsesGex and (na(loadedGexDayKey) or dayKey != loadedGexDayKey or loadedGexAsset != gexAsset)
    loadedGexDayKey := dayKey
    loadedGexAsset := gexAsset
    array.clear(activeGexStrikes)
    array.clear(activeGexGamma)

    matchedHistory = false
    if gexAsset == "NQ"
        if useHistoricalGexDataset and array.size(gexHistDayKeysNq) == array.size(gexHistStrikesCsvNq) and array.size(gexHistDayKeysNq) == array.size(gexHistGammaCsvNq)
            for i = 0 to array.size(gexHistDayKeysNq) - 1
                if array.get(gexHistDayKeysNq, i) == dayKey
                    f_parse_csv_to_float_array(array.get(gexHistStrikesCsvNq, i), activeGexStrikes)
                    f_parse_csv_to_float_array(array.get(gexHistGammaCsvNq, i), activeGexGamma)
                    matchedHistory := true
                    break
        if not matchedHistory
            for i = 0 to array.size(gexStrikesNq) - 1
                array.push(activeGexStrikes, array.get(gexStrikesNq, i))
                array.push(activeGexGamma, array.get(gexGammaNq, i))
    else if gexAsset == "ES"
        if useHistoricalGexDataset and array.size(gexHistDayKeysEs) == array.size(gexHistStrikesCsvEs) and array.size(gexHistDayKeysEs) == array.size(gexHistGammaCsvEs)
            for i = 0 to array.size(gexHistDayKeysEs) - 1
                if array.get(gexHistDayKeysEs, i) == dayKey
                    f_parse_csv_to_float_array(array.get(gexHistStrikesCsvEs, i), activeGexStrikes)
                    f_parse_csv_to_float_array(array.get(gexHistGammaCsvEs, i), activeGexGamma)
                    matchedHistory := true
                    break
        if not matchedHistory
            for i = 0 to array.size(gexStrikesEs) - 1
                array.push(activeGexStrikes, array.get(gexStrikesEs, i))
                array.push(activeGexGamma, array.get(gexGammaEs, i))

if assetUsesGex and array.size(activeGexStrikes) != array.size(activeGexGamma)
    runtime.error("Active GEX arrays must have the same size.")
if assetUsesGex and array.size(activeGexStrikes) == 0
    runtime.error("Active GEX arrays are empty for selected asset. Paste snapshot or historical data block.")

fastEma = ta.ema(close, effectiveFastLen)
slowEma = ta.ema(close, effectiveSlowLen)
rsi = ta.rsi(close, effectiveRsiLen)

trendUp = fastEma > slowEma
trendDown = fastEma < slowEma
betweenEma = close <= math.max(fastEma, slowEma) and close >= math.min(fastEma, slowEma)
pullbackRed = close < open
pullbackGreen = close > open

longMomentumOk = not effectiveUseRsiFilter or rsi > effectiveRsiLevel
shortMomentumOk = not effectiveUseRsiFilter or rsi < effectiveRsiLevel

entryRefLong = math.min(fastEma, slowEma)
entryRefShort = math.max(fastEma, slowEma)
distLongPips = math.abs(close - entryRefLong) / pipSize
distShortPips = math.abs(close - entryRefShort) / pipSize
longDistanceOk = distLongPips <= effectiveMaxEntryPips
shortDistanceOk = distShortPips <= effectiveMaxEntryPips

longPullbackOk = not effectiveRequirePullbackColor or pullbackRed
shortPullbackOk = not effectiveRequirePullbackColor or pullbackGreen

float netGex = 0.0
float nearestAbove = na
float nearestBelow = na
activeGexCount = array.size(activeGexStrikes)
if activeGexCount > 0
    for i = 0 to activeGexCount - 1
        strike = array.get(activeGexStrikes, i)
        gamma = array.get(activeGexGamma, i)
        netGex += gamma
        if strike >= close and (na(nearestAbove) or strike < nearestAbove)
            nearestAbove := strike
        if strike <= close and (na(nearestBelow) or strike > nearestBelow)
            nearestBelow := strike

nearResistance = not na(nearestAbove) and math.abs(close - nearestAbove) <= gexBandPts
nearSupport = not na(nearestBelow) and math.abs(close - nearestBelow) <= gexBandPts
gexFilterActiveBar = assetUsesGex and useGexFilter and (applyGexToHistory or time >= gexActiveFrom)
gexExitActiveBar = assetUsesGex and useGexExit and (applyGexToHistory or time >= gexActiveFrom)
allowLongGex = not gexFilterActiveBar or (netGex > 0 and not nearResistance)
allowShortGex = not gexFilterActiveBar or (netGex <= 0 and not nearSupport)

longSignalBase = allowLongs and trendUp and betweenEma and longPullbackOk and longMomentumOk and longDistanceOk
shortSignalBase = allowShorts and trendDown and betweenEma and shortPullbackOk and shortMomentumOk and shortDistanceOk
longSignal = longSignalBase and allowLongGex
shortSignal = shortSignalBase and allowShortGex

if longSignal and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, qty=contractsPerTrade)
if shortSignal and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, qty=contractsPerTrade)

tp1Pct = math.min(math.max(effectiveTp1ClosePct, 1.0), 99.0)
tp2Pct = 100.0 - tp1Pct

longStop = strategy.position_avg_price - effectiveStopPips * pipSize
longTp1 = strategy.position_avg_price + effectiveTp1Pips * pipSize
longTp2 = strategy.position_avg_price + effectiveTp2Pips * pipSize

shortStop = strategy.position_avg_price + effectiveStopPips * pipSize
shortTp1 = strategy.position_avg_price - effectiveTp1Pips * pipSize
shortTp2 = strategy.position_avg_price - effectiveTp2Pips * pipSize

if strategy.position_size > 0
    strategy.exit("L-TP1", from_entry="Long", stop=longStop, limit=longTp1, qty_percent=tp1Pct)
    strategy.exit("L-TP2", from_entry="Long", stop=longStop, limit=longTp2, qty_percent=tp2Pct)
if strategy.position_size < 0
    strategy.exit("S-TP1", from_entry="Short", stop=shortStop, limit=shortTp1, qty_percent=tp1Pct)
    strategy.exit("S-TP2", from_entry="Short", stop=shortStop, limit=shortTp2, qty_percent=tp2Pct)

rsiCrossUnderMid = ta.crossunder(rsi, effectiveRsiLevel)
rsiCrossOverMid = ta.crossover(rsi, effectiveRsiLevel)
longMomentumFlip = strategy.position_size > 0 and rsiCrossUnderMid
shortMomentumFlip = strategy.position_size < 0 and rsiCrossOverMid
if effectiveUseMomentumExit and longMomentumFlip
    strategy.close("Long", comment="RSI Momentum Flip")
if effectiveUseMomentumExit and shortMomentumFlip
    strategy.close("Short", comment="RSI Momentum Flip")
if gexExitActiveBar and strategy.position_size > 0 and nearResistance
    strategy.close("Long", comment="GEX Resistance")
if gexExitActiveBar and strategy.position_size < 0 and nearSupport
    strategy.close("Short", comment="GEX Support")

plot(fastEma, "EMA Fast", color=color.new(color.aqua, 0))
plot(slowEma, "EMA Slow", color=color.new(color.orange, 0))
plot(showGexLevels and assetUsesGex ? nearestAbove : na, "Nearest GEX Resistance", color=color.new(color.red, 0), linewidth=2, style=plot.style_linebr)
plot(showGexLevels and assetUsesGex ? nearestBelow : na, "Nearest GEX Support", color=color.new(color.green, 0), linewidth=2, style=plot.style_linebr)
plotshape(showEntrySignals and longSignal, title="Long Signal", style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 0), size=size.tiny, text="L")
plotshape(showEntrySignals and shortSignal, title="Short Signal", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.tiny, text="S")

if longSignal
    alert("Long Entry Setup: 9/21 scalping long setup", alert.freq_once_per_bar_close)
if shortSignal
    alert("Short Entry Setup: 9/21 scalping short setup", alert.freq_once_per_bar_close)

var table profileTbl = table.new(position.top_right, 2, 9, frame_color=color.new(color.gray, 70), border_width=1)
if showProfileTable and (barstate.islastconfirmedhistory or barstate.isrealtime)
    table.cell(profileTbl, 0, 0, "Setting", text_color=color.white, bgcolor=color.new(color.blue, 70))
    table.cell(profileTbl, 1, 0, "Active", text_color=color.white, bgcolor=color.new(color.blue, 70))
    table.cell(profileTbl, 0, 1, "Profile", text_color=color.white)
    table.cell(profileTbl, 1, 1, profilePreset, text_color=color.white)
    table.cell(profileTbl, 0, 2, "EMA", text_color=color.white)
    table.cell(profileTbl, 1, 2, str.tostring(effectiveFastLen) + "/" + str.tostring(effectiveSlowLen), text_color=color.white)
    table.cell(profileTbl, 0, 3, "RSI Filter", text_color=color.white)
    table.cell(profileTbl, 1, 3, str.tostring(effectiveUseRsiFilter), text_color=color.white)
    table.cell(profileTbl, 0, 4, "Max Entry Pips", text_color=color.white)
    table.cell(profileTbl, 1, 4, str.tostring(effectiveMaxEntryPips, "#.##"), text_color=color.white)
    table.cell(profileTbl, 0, 5, "Stop Pips", text_color=color.white)
    table.cell(profileTbl, 1, 5, str.tostring(effectiveStopPips, "#.##"), text_color=color.white)
    table.cell(profileTbl, 0, 6, "TP1 / TP2", text_color=color.white)
    table.cell(profileTbl, 1, 6, str.tostring(effectiveTp1Pips, "#.##") + " / " + str.tostring(effectiveTp2Pips, "#.##"), text_color=color.white)
    table.cell(profileTbl, 0, 7, "TP1 Close %", text_color=color.white)
    table.cell(profileTbl, 1, 7, str.tostring(tp1Pct, "#.##"), text_color=color.white)
    table.cell(profileTbl, 0, 8, "Momentum Exit", text_color=color.white)
    table.cell(profileTbl, 1, 8, str.tostring(effectiveUseMomentumExit), text_color=color.white)

