f_parse_csv_to_float_array(string csv, float[] outArr) =>
    array.clear(outArr)
    tokens = str.split(csv, "|")
    for i = 0 to array.size(tokens) - 1
        v = str.tonumber(array.get(tokens, i))
        if not na(v)
            array.push(outArr, v)

var float[] activeGexStrikes = array.new_float()
var float[] activeGexGamma = array.new_float()
var int loadedGexDayKey = na
var bool matchedHistoricalToday = false

dayKey = year(time) * 10000 + month(time) * 100 + dayofmonth(time)
if na(loadedGexDayKey) or dayKey != loadedGexDayKey
    loadedGexDayKey := dayKey
    array.clear(activeGexStrikes)
    array.clear(activeGexGamma)
    matchedHistoricalToday := false

    matchedHistory = false
    if useHistoricalGexDataset and array.size(gexHistDayKeys) == array.size(gexHistStrikesCsv) and array.size(gexHistDayKeys) == array.size(gexHistGammaCsv)
        for i = 0 to array.size(gexHistDayKeys) - 1
            if array.get(gexHistDayKeys, i) == dayKey
                f_parse_csv_to_float_array(array.get(gexHistStrikesCsv, i), activeGexStrikes)
                f_parse_csv_to_float_array(array.get(gexHistGammaCsv, i), activeGexGamma)
                matchedHistory := true
                matchedHistoricalToday := true
                break

    if not matchedHistory and not requireMatchedHistoricalGex
        for i = 0 to array.size(gexStrikes) - 1
            array.push(activeGexStrikes, array.get(gexStrikes, i))
            array.push(activeGexGamma, array.get(gexGamma, i))

if array.size(activeGexStrikes) != array.size(activeGexGamma)
    runtime.error("Active GEX arrays must have the same size.")
gexDataReady = array.size(activeGexStrikes) > 0

inSession = not na(time(timeframe.period, sessionInput, sessionTz))
newSession = inSession and not inSession[1]
sessionEnd = not inSession and inSession[1]

var int orbStartTs = na
var int orbEndTs = na
var float orbHigh = na
var float orbLow = na
var bool orbLocked = false
var bool tradedThisSession = false

if newSession
    orbStartTs := time
    orbEndTs := orbStartTs + effectiveOrbMinutes * 60 * 1000
    orbHigh := high
    orbLow := low
    orbLocked := false
    tradedThisSession := false

if inSession and not orbLocked
    inOrbWindow = time < orbEndTs
    orbHigh := inOrbWindow ? (na(orbHigh) ? high : math.max(orbHigh, high)) : orbHigh
    orbLow := inOrbWindow ? (na(orbLow) ? low : math.min(orbLow, low)) : orbLow
    orbLocked := not inOrbWindow

if sessionEnd
    orbLocked := false

fastEma = ta.ema(close, effectiveFastEma)
slowEma = ta.ema(close, effectiveSlowEma)
trendLong = not effectiveUseTrend or fastEma > slowEma
trendShort = not effectiveUseTrend or fastEma < slowEma

float netGex = 0.0
float nearestAbove = na
float nearestBelow = na
for i = 0 to array.size(activeGexStrikes) - 1
    strike = array.get(activeGexStrikes, i)
    gamma = array.get(activeGexGamma, i)
    netGex += gamma
    if strike >= close and (na(nearestAbove) or strike < nearestAbove)
        nearestAbove := strike
    if strike <= close and (na(nearestBelow) or strike > nearestBelow)
        nearestBelow := strike

nearResistance = not na(nearestAbove) and math.abs(close - nearestAbove) <= gexBandPts
nearSupport = not na(nearestBelow) and math.abs(close - nearestBelow) <= gexBandPts
gexFilterActiveBar = useGexFilter and gexDataReady and (applyGexToHistory or time >= gexActiveFrom)
gexExitActiveBar = useGexExit and gexDataReady and (applyGexToHistory or time >= gexActiveFrom)
allowLongGex = not gexFilterActiveBar or (netGex > 0 and not nearResistance)
allowShortGex = not gexFilterActiveBar or (netGex <= 0 and not nearSupport)

longBreakout = orbLocked and trendLong and ta.crossover(high, orbHigh)
shortBreakout = orbLocked and trendShort and ta.crossunder(low, orbLow)

longRetest = low <= orbHigh and close > orbHigh
shortRetest = high >= orbLow and close < orbLow
longTriggerBase = effectiveRequireRetest ? (longBreakout and longRetest) : longBreakout
shortTriggerBase = effectiveRequireRetest ? (shortBreakout and shortRetest) : shortBreakout
longTrigger = longTriggerBase and allowLongGex
shortTrigger = shortTriggerBase and allowShortGex

canTrade = inSession and orbLocked and not tradedThisSession and strategy.position_size == 0

if canTrade and longTrigger
    strategy.entry("Long", strategy.long, qty=contractsPerTrade)
    tradedThisSession := true

if canTrade and shortTrigger
    strategy.entry("Short", strategy.short, qty=contractsPerTrade)
    tradedThisSession := true

longRisk = strategy.position_avg_price * (effectiveRiskPct / 100.0)
shortRisk = strategy.position_avg_price * (effectiveRiskPct / 100.0)

longStop = strategy.position_avg_price - longRisk
longTp1 = strategy.position_avg_price + longRisk * effectiveTp1R
longTp2 = strategy.position_avg_price + longRisk * effectiveTp2R

shortStop = strategy.position_avg_price + shortRisk
shortTp1 = strategy.position_avg_price - shortRisk * effectiveTp1R
shortTp2 = strategy.position_avg_price - shortRisk * effectiveTp2R

if strategy.position_size > 0
    strategy.exit("L-TP1", from_entry="Long", stop=longStop, limit=longTp1, qty_percent=50)
    strategy.exit("L-TP2", from_entry="Long", stop=longStop, limit=longTp2, qty_percent=50)

if strategy.position_size < 0
    strategy.exit("S-TP1", from_entry="Short", stop=shortStop, limit=shortTp1, qty_percent=50)
    strategy.exit("S-TP2", from_entry="Short", stop=shortStop, limit=shortTp2, qty_percent=50)

if effectiveMoveToBE and strategy.position_size > 0 and high >= longTp1
    strategy.exit("L-SL-BE", from_entry="Long", stop=strategy.position_avg_price)
if effectiveMoveToBE and strategy.position_size < 0 and low <= shortTp1
    strategy.exit("S-SL-BE", from_entry="Short", stop=strategy.position_avg_price)

if gexExitActiveBar and strategy.position_size > 0 and nearResistance
    strategy.close("Long", comment="GEX Resistance")
if gexExitActiveBar and strategy.position_size < 0 and nearSupport
    strategy.close("Short", comment="GEX Support")

plot(showLevels and orbLocked ? orbHigh : na, "ORB High", color=color.new(color.green, 0), linewidth=2, style=plot.style_linebr)
plot(showLevels and orbLocked ? orbLow : na, "ORB Low", color=color.new(color.red, 0), linewidth=2, style=plot.style_linebr)
plot(fastEma, "Fast EMA", color=color.new(color.blue, 0))
plot(slowEma, "Slow EMA", color=color.new(color.orange, 0))
plot(showGexLevels ? nearestAbove : na, "Nearest GEX Resistance", color=color.new(color.red, 0), linewidth=2, style=plot.style_linebr)
plot(showGexLevels ? nearestBelow : na, "Nearest GEX Support", color=color.new(color.green, 0), linewidth=2, style=plot.style_linebr)

plotshape(showSignals and longTrigger and canTrade, title="Long Trigger", style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 0), size=size.tiny, text="L")
plotshape(showSignals and shortTrigger and canTrade, title="Short Trigger", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.tiny, text="S")

if longTrigger and canTrade
    alert("Long ORB trigger detected", alert.freq_once_per_bar_close)
if shortTrigger and canTrade
    alert("Short ORB trigger detected", alert.freq_once_per_bar_close)

var table presetTbl = table.new(position.bottom_right, 2, 10, frame_color=color.new(color.gray, 65), border_width=1)
if barstate.islast and showPresetTable
    table.cell(presetTbl, 0, 0, "Setting", text_color=color.white, bgcolor=color.new(color.blue, 70))
    table.cell(presetTbl, 1, 0, "Active", text_color=color.white, bgcolor=color.new(color.blue, 70))
    table.cell(presetTbl, 0, 1, "Profile", text_color=color.white)
    table.cell(presetTbl, 1, 1, profilePreset, text_color=color.white)
    table.cell(presetTbl, 0, 2, "ORB Minutes", text_color=color.white)
    table.cell(presetTbl, 1, 2, str.tostring(effectiveOrbMinutes), text_color=color.white)
    table.cell(presetTbl, 0, 3, "EMA Fast/Slow", text_color=color.white)
    table.cell(presetTbl, 1, 3, str.tostring(effectiveFastEma) + "/" + str.tostring(effectiveSlowEma), text_color=color.white)
    table.cell(presetTbl, 0, 4, "Trend Filter", text_color=color.white)
    table.cell(presetTbl, 1, 4, str.tostring(effectiveUseTrend), text_color=color.white)
    table.cell(presetTbl, 0, 5, "Require Retest", text_color=color.white)
    table.cell(presetTbl, 1, 5, str.tostring(effectiveRequireRetest), text_color=color.white)
    table.cell(presetTbl, 0, 6, "Risk %", text_color=color.white)
    table.cell(presetTbl, 1, 6, str.tostring(effectiveRiskPct, "#.##"), text_color=color.white)
    table.cell(presetTbl, 0, 7, "TP1 / TP2", text_color=color.white)
    table.cell(presetTbl, 1, 7, str.tostring(effectiveTp1R, "#.##") + " / " + str.tostring(effectiveTp2R, "#.##"), text_color=color.white)
    table.cell(presetTbl, 0, 8, "Move To BE", text_color=color.white)
    table.cell(presetTbl, 1, 8, str.tostring(effectiveMoveToBE), text_color=color.white)
    table.cell(presetTbl, 0, 9, "Contracts", text_color=color.white)
    table.cell(presetTbl, 1, 9, str.tostring(contractsPerTrade), text_color=color.white)

