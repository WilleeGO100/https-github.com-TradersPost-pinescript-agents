//@version=6
strategy("NQ GEX Regime Template", overlay=true, initial_capital=100000, pyramiding=0, process_orders_on_close=true)

type GexRow
    int dayKey
    string symbol
    float spot
    float zeroGamma
    float callWall
    float putWall

groupGex = "GEX Filter"
groupSignal = "Signal"
groupRisk = "Risk"

useGexFilter = input.bool(true, "Use GEX Regime Filter", group=groupGex)
bandPts = input.float(20.0, "Near-Level Band (Points)", minval=0.25, step=0.25, group=groupGex)
showNearestLevels = input.bool(true, "Plot Nearest GEX Levels", group=groupGex)

fastLen = input.int(21, "Fast EMA", minval=1, group=groupSignal)
slowLen = input.int(55, "Slow EMA", minval=1, group=groupSignal)

atrLen = input.int(14, "ATR Length", minval=1, group=groupRisk)
atrStopMult = input.float(2.0, "ATR Stop Mult", minval=0.25, step=0.25, group=groupRisk)

// PASTE LIVE GEX BLOCK HERE (generated by tools/gexbot_nq_to_pine_block.py)
// --- BEGIN AUTO-GENERATED LIVE GEX ROW (NQ_NDX) ---
string gexGeneratedAt = "2026-04-13T05:12:48.022025+00:00"
string gexSourceUrl = "https://api.gexbot.com/NQ_NDX/classic/zero?date=2026-04-13"
var GexRow[] gexLiveRows = array.from(
    GexRow.new(20260413, "NQ_NDX", 25541.89, 25131.09, 25540.07, 25060.07)
)
// --- END AUTO-GENERATED LIVE GEX ROW (NQ_NDX) ---

f_dayKey(_t) =>
    year(_t) * 10000 + month(_t) * 100 + dayofmonth(_t)

f_findGexIndex(_rows, _dayKey) =>
    int result = na
    if array.size(_rows) > 0
        for i = 0 to array.size(_rows) - 1
            row = array.get(_rows, i)
            if row.dayKey <= _dayKey
                result := i
    result

f_unpackRow(_row) =>
    [_row.dayKey, _row.symbol, _row.spot, _row.zeroGamma, _row.callWall, _row.putWall]

todayKey = f_dayKey(time)
gexRowIndex = f_findGexIndex(gexLiveRows, todayKey)
if na(gexRowIndex)
    runtime.error("Live GEX row array is empty.")

[gexDayKey, gexSymbol, gexSpot, gexZeroGamma, gexCallWall, gexPutWall] = f_unpackRow(array.get(gexLiveRows, gexRowIndex))

nearResistance = not na(gexCallWall) and math.abs(close - gexCallWall) <= bandPts
nearSupport = not na(gexPutWall) and math.abs(close - gexPutWall) <= bandPts

bullRegime = na(gexZeroGamma) ? true : close >= gexZeroGamma
bearRegime = na(gexZeroGamma) ? true : close < gexZeroGamma

allowLong = not useGexFilter or (bullRegime and not nearResistance)
allowShort = not useGexFilter or (bearRegime and not nearSupport)

fastEma = ta.ema(close, fastLen)
slowEma = ta.ema(close, slowLen)
atr = ta.atr(atrLen)

longSignal = ta.crossover(fastEma, slowEma)
shortSignal = ta.crossunder(fastEma, slowEma)

if longSignal and allowLong and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
if shortSignal and allowShort and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)

if strategy.position_size > 0
    strategy.exit("Long Stop", from_entry="Long", stop=strategy.position_avg_price - atr * atrStopMult)
if strategy.position_size < 0
    strategy.exit("Short Stop", from_entry="Short", stop=strategy.position_avg_price + atr * atrStopMult)

plot(fastEma, "Fast EMA", color=color.new(color.aqua, 0))
plot(slowEma, "Slow EMA", color=color.new(color.orange, 0))
plot(showNearestLevels ? gexZeroGamma : na, "Zero Gamma", color=color.new(color.yellow, 0), style=plot.style_linebr, linewidth=2)
plot(showNearestLevels ? gexCallWall : na, "Call Wall", color=color.new(color.red, 0), style=plot.style_linebr, linewidth=2)
plot(showNearestLevels ? gexPutWall : na, "Put Wall", color=color.new(color.green, 0), style=plot.style_linebr, linewidth=2)
plot(showNearestLevels ? gexSpot : na, "GEX Spot", color=color.new(color.blue, 35), style=plot.style_circles, linewidth=2)

plotshape(longSignal and allowLong, title="Long Allowed", style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 0), size=size.tiny, text="L")
plotshape(shortSignal and allowShort, title="Short Allowed", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.tiny, text="S")
